{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"],
        "excludes": [
            // Live server glue: ServeCommand blocks on a real amphp event loop, so it is
            // exercised by the SDK's conformance suite, not units. Mirrored in
            // phpunit.xml.dist (source exclude) and codecov.yml (ignore).
            "Console/ServeCommand.php",
            // Service-provider lifecycle glue: register()/boot() wiring (bindings, command
            // and macro registration, route + config publishing). Behaviour is integration-
            // tested (bindings/route in the provider tests), but mutating the wiring itself
            // produces escaped mutants a unit test can't meaningfully kill — like the SDK's
            // live-socket Server/* exclusion. These stay in coverage (the bindings ARE
            // covered), only out of the mutation calc.
            "RestateServiceProvider.php",
            "Queue/RestateQueueServiceProvider.php",
            "Discovery/RestateMakeServiceProvider.php",
            "Codegen/CodegenServiceProvider.php",
            "Scheduling/RestateSchedulerServiceProvider.php",
            "Logging/RestateLogServiceProvider.php",
            "Logging/RestateObservabilityServiceProvider.php"
        ]
    },
    "mutators": {
        "@default": true
    },
    "testFramework": "phpunit",
    "tmpDir": "build/infection",
    // Floors sit a few points below the achieved MSI (68% / covered 77%) so they gate
    // regressions while tolerating run-to-run variance; raise them as coverage of the
    // framework-glue (providers, commands) grows.
    "minMsi": 64,
    "minCoveredMsi": 73,
    "logs": {
        "text": "build/infection/infection.log",
        "html": "build/infection/infection.html",
        "summary": "build/infection/summary.log",
        "stryker": {
            "badge": "main"
        }
    }
}
