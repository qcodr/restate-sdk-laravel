{
    "name": "qcodr/restate-laravel-e2e-app",
    "description": "Minimal Laravel app that hosts the Restate Laravel package for the end-to-end harness. Not published.",
    "type": "project",
    "license": "Apache-2.0",
    "repositories": [
        {
            "type": "path",
            "url": "../../..",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "qcodr/restate-sdk-laravel": "*",
        "amphp/http-server": "^3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
