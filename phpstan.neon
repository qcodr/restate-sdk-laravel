includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-phpunit/rules.neon

parameters:
    level: max
    paths:
        - src
        - tests
    # The e2e harness (tests/e2e) is a standalone Laravel app + docker stack, not part of
    # the package's analysed code; it has its own composer project and is run via `make e2e`.
    excludePaths:
        - tests/e2e
    treatPhpDocTypesAsCertain: false
